/data/raw/*
/data/processed/*
/outputs/checkpoints/*
/outputs/samples/*
/outputs/quantized_models/*
!/data/raw/.gitkeep
!/data/raw/*.dvc
!/data/processed/.gitkeep
!/data/processed/*.dvc
!/outputs/checkpoints/.gitkeep
!/outputs/checkpoints/*.dvc
!/outputs/samples/.gitkeep
!/outputs/samples/*.dvc
!/outputs/quantized_models/.gitkeep
!/outputs/quantized_models/*.dvc

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ── Environment / secrets ───────────────────────────────────────────────
.env
.venv/
venv/

# ── MLflow local artifacts (we use remote tracking, but ignore local mlruns) ─
mlruns/
mlartifacts/

# ── Jupyter ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_meta

# ── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.dvc/config
